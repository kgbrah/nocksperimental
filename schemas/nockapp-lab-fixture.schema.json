{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nocksperimental.dev/schemas/nockapp-lab-fixture.schema.json",
  "title": "Nocksperimental NockApp Lab Fixture",
  "type": "object",
  "required": ["id", "app", "environment", "initialState", "steps", "invariants"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "expectRejected": {
      "type": "boolean",
      "description": "Negative control: the fixture is an exploit attempt that MUST be caught. When true, a failing run (the exploit detected) reads as pass; a passing run (exploit missed) reads as fail."
    },
    "app": {
      "type": "object",
      "required": ["name", "slug", "version", "kernel"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "version": { "type": "string" },
        "kernel": { "type": "string" },
        "kernelHash": {
          "type": "string",
          "description": "Hash (hoonc/jam) of the COMPILED deployed kernel. When present and the run executes the real kernel (environment.mode=kernel), the issued cert binds to it; otherwise the cert is model-attested only."
        },
        "baseDeploymentHash": {
          "type": "string",
          "description": "sha256 of the canonical {chainId, inboxAddress, nockAddress} deployment identity. Written by the runner on a successful live-base run; binds an app-report cert to the exact deployed contracts."
        }
      }
    },
    "environment": {
      "type": "object",
      "required": ["mode", "grpcEndpoint", "fakenetCommand", "notes"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["mock-fakenet", "local-fakenet", "docker-fakenet", "kernel", "live-base"]
        },
        "grpcEndpoint": { "type": "string" },
        "fakenetCommand": { "type": "string" },
        "balanceCheck": {
          "$ref": "#/$defs/balanceCheck"
        },
        "chainCheck": {
          "$ref": "#/$defs/chainCheck"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "baseRpcUrl": {
          "type": "string",
          "description": "EVM JSON-RPC URL for live-base mode. Use a ${ENV_VAR} literal to keep a private endpoint out of the committed fixture; falls back to a public Base Sepolia RPC when unset."
        },
        "baseInboxAddress": { "type": "string", "description": "MessageInbox.sol address (mints) for live-base mode." },
        "baseNockAddress": { "type": "string", "description": "Nock.sol address (burns) for live-base mode." },
        "baseChainId": { "type": "number", "description": "EVM chainId for live-base mode (e.g. 84532 = Base Sepolia)." },
        "baseFromBlock": { "type": ["number", "string"], "description": "getLogs window start (block number or a block tag like 'earliest')." },
        "baseToBlock": { "type": ["number", "string"], "description": "getLogs window end (block number or 'latest')." },
        "baseConfirmationDepth": { "type": "number", "description": "Required confirmations fed to finality-depth for live-base mints." },
        "baseAppRequiredConfirmations": { "type": "number", "description": "App-declared confirmation floor fed to finality-adequacy for live-base settles." }
      }
    },
    "actors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "pkh"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "pkh": { "type": "string" }
        }
      }
    },
    "invariantPacks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "initialState": {
      "type": "object"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "enum": ["fakenet", "poke", "peek", "invariant", "bridge"]
          },
          "title": { "type": "string" },
          "actor": { "type": "string" },
          "target": { "type": "string" },
          "input": {},
          "operation": {
            "$ref": "#/$defs/operation"
          },
          "operations": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/operation"
            }
          },
          "statePatch": {
            "type": "object"
          },
          "adapter": {
            "$ref": "#/$defs/stepAdapter"
          },
          "expectation": { "type": "string" },
          "expect": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "equals": {}
            }
          }
        }
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "kind"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": {
            "enum": ["critical", "high", "medium", "low"]
          },
          "kind": {
            "enum": [
              "numeric-min",
              "state-equals",
              "poke-actors-declared",
              "supply-conservation",
              "timeline-state",
              "authorized-actor",
              "numeric-range",
              "array-length-min",
              "array-length-max",
              "temporal-ordering",
              "custom-function",
              "monotonic-strict"
            ]
          },
          "path": { "type": "string" },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "equals": {},
          "balancesPath": { "type": "string" },
          "supplyPath": { "type": "string" },
          "actors": {
            "type": "array",
            "items": { "type": "string" }
          },
          "stepType": {
            "enum": ["fakenet", "poke", "peek", "invariant", "bridge"]
          },
          "field": { "type": "string" },
          "before": {},
          "after": {},
          "fn": { "type": "string" },
          "packId": { "type": "string" }
        },
        "allOf": [{ "$ref": "#/$defs/invariantKindRequirements" }]
      }
    },
    "alertPolicies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "condition", "message", "clearMessage"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": {
            "enum": ["critical", "warning", "info"]
          },
          "condition": {
            "type": "object",
            "required": ["path", "equals"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "equals": {}
            }
          },
          "message": { "type": "string" },
          "clearMessage": { "type": "string" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "environment": { "properties": { "mode": { "const": "live-base" } } } } },
      "then": { "properties": { "environment": { "required": ["baseInboxAddress", "baseNockAddress"] } } }
    }
  ],
  "$defs": {
    "invariantKindRequirements": {
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "numeric-min" } } },
          "then": { "required": ["path", "min"] }
        },
        {
          "if": { "properties": { "kind": { "const": "state-equals" } } },
          "then": { "required": ["path", "equals"] }
        },
        {
          "if": { "properties": { "kind": { "const": "timeline-state" } } },
          "then": { "required": ["path", "equals"] }
        },
        {
          "if": { "properties": { "kind": { "const": "supply-conservation" } } },
          "then": { "required": ["balancesPath", "supplyPath"] }
        },
        {
          "if": { "properties": { "kind": { "const": "authorized-actor" } } },
          "then": {
            "required": ["actors", "stepType"],
            "properties": { "actors": { "minItems": 1 } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "numeric-range" } } },
          "then": { "required": ["path", "min", "max"] }
        },
        {
          "if": { "properties": { "kind": { "const": "array-length-min" } } },
          "then": { "required": ["path", "min"] }
        },
        {
          "if": { "properties": { "kind": { "const": "array-length-max" } } },
          "then": { "required": ["path", "max"] }
        },
        {
          "if": { "properties": { "kind": { "const": "temporal-ordering" } } },
          "then": { "required": ["path", "field", "before", "after"] }
        },
        {
          "if": { "properties": { "kind": { "const": "custom-function" } } },
          "then": { "required": ["fn", "path"] }
        },
        {
          "if": { "properties": { "kind": { "const": "monotonic-strict" } } },
          "then": { "required": ["path"] }
        }
      ]
    },
    "balanceCheck": {
      "type": "object",
      "required": ["address", "command"],
      "additionalProperties": false,
      "properties": {
        "address": { "type": "string" },
        "command": {
          "$ref": "#/$defs/command"
        }
      }
    },
    "chainCheck": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "$ref": "#/$defs/command"
        }
      }
    },
    "stepAdapter": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "$ref": "#/$defs/command"
        },
        "timeoutMs": {
          "type": "number",
          "description": "Adapter command timeout in milliseconds (default 15000). Raise for slow node-backed commands."
        },
        "expect": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stdoutIncludes": { "type": "string" }
          }
        }
      }
    },
    "command": {
      "type": "object",
      "required": ["program"],
      "additionalProperties": false,
      "properties": {
        "program": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "operation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "path", "by"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "increment" },
            "path": { "type": "string" },
            "by": { "type": "number" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "path", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "set" },
            "path": { "type": "string" },
            "value": {}
          }
        },
        {
          "type": "object",
          "required": ["kind", "fromPath", "toPath", "amount"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "transfer" },
            "fromPath": { "type": "string" },
            "toPath": { "type": "string" },
            "amount": { "type": "number" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "path", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "append-event" },
            "path": { "type": "string" },
            "value": {}
          }
        }
      ]
    }
  }
}
