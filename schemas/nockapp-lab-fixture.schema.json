{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nocksperimental.dev/schemas/nockapp-lab-fixture.schema.json",
  "title": "Nocksperimental NockApp Lab Fixture",
  "type": "object",
  "required": ["id", "app", "environment", "initialState", "steps", "invariants"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "app": {
      "type": "object",
      "required": ["name", "slug", "version", "kernel"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "version": { "type": "string" },
        "kernel": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "required": ["mode", "grpcEndpoint", "fakenetCommand", "notes"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["mock-fakenet", "local-fakenet", "docker-fakenet"]
        },
        "grpcEndpoint": { "type": "string" },
        "fakenetCommand": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "actors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "pkh"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "pkh": { "type": "string" }
        }
      }
    },
    "invariantPacks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "initialState": {
      "type": "object"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "enum": ["fakenet", "poke", "peek", "invariant", "bridge"]
          },
          "title": { "type": "string" },
          "actor": { "type": "string" },
          "target": { "type": "string" },
          "input": {},
          "operation": {
            "$ref": "#/$defs/operation"
          },
          "operations": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/operation"
            }
          },
          "statePatch": {
            "type": "object"
          },
          "expectation": { "type": "string" },
          "expect": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "equals": {}
            }
          }
        }
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "kind"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": {
            "enum": ["critical", "high", "medium", "low"]
          },
          "kind": {
            "enum": [
              "numeric-min",
              "state-equals",
              "poke-actors-declared",
              "supply-conservation",
              "timeline-state",
              "authorized-actor"
            ]
          },
          "path": { "type": "string" },
          "min": { "type": "number" },
          "equals": {},
          "balancesPath": { "type": "string" },
          "supplyPath": { "type": "string" },
          "actors": {
            "type": "array",
            "items": { "type": "string" }
          },
          "stepType": {
            "enum": ["fakenet", "poke", "peek", "invariant", "bridge"]
          },
          "packId": { "type": "string" }
        }
      }
    },
    "alertPolicies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "condition", "message", "clearMessage"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": {
            "enum": ["critical", "warning", "info"]
          },
          "condition": {
            "type": "object",
            "required": ["path", "equals"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "equals": {}
            }
          },
          "message": { "type": "string" },
          "clearMessage": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "operation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "path", "by"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "increment" },
            "path": { "type": "string" },
            "by": { "type": "number" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "path", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "set" },
            "path": { "type": "string" },
            "value": {}
          }
        },
        {
          "type": "object",
          "required": ["kind", "fromPath", "toPath", "amount"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "transfer" },
            "fromPath": { "type": "string" },
            "toPath": { "type": "string" },
            "amount": { "type": "number" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "path", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "append-event" },
            "path": { "type": "string" },
            "value": {}
          }
        }
      ]
    }
  }
}
