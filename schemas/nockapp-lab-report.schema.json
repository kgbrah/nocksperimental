{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nocksperimental.dev/schemas/nockapp-lab-report.schema.json",
  "title": "Nocksperimental NockApp Lab Report",
  "type": "object",
  "required": [
    "reportId",
    "fixtureId",
    "generatedAt",
    "app",
    "environment",
    "summary",
    "invariantPacks",
    "steps",
    "invariants",
    "alerts",
    "adapterObservations",
    "stateSnapshots",
    "stateDiffs",
    "nextActions"
  ],
  "additionalProperties": false,
  "properties": {
    "reportId": { "type": "string" },
    "fixtureId": { "type": "string" },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "app": {
      "type": "object",
      "required": ["name", "slug", "version", "kernel"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "version": { "type": "string" },
        "kernel": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "required": ["mode", "grpcEndpoint", "fakenetCommand", "notes"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["mock-fakenet", "local-fakenet", "docker-fakenet"]
        },
        "grpcEndpoint": { "type": "string" },
        "fakenetCommand": { "type": "string" },
        "balanceCheck": {
          "$ref": "#/$defs/balanceCheck"
        },
        "chainCheck": {
          "$ref": "#/$defs/chainCheck"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "stepsPassed",
        "stepsFailed",
        "invariantsPassed",
        "invariantsFailed",
        "alertsClear",
        "alertsTriggered",
        "snapshotsCaptured",
        "durationMs"
      ],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["pass", "warn", "fail"] },
        "stepsPassed": { "type": "integer", "minimum": 0 },
        "stepsFailed": { "type": "integer", "minimum": 0 },
        "invariantsPassed": { "type": "integer", "minimum": 0 },
        "invariantsFailed": { "type": "integer", "minimum": 0 },
        "alertsClear": { "type": "integer", "minimum": 0 },
        "alertsTriggered": { "type": "integer", "minimum": 0 },
        "snapshotsCaptured": { "type": "integer", "minimum": 0 },
        "durationMs": { "type": "integer", "minimum": 0 }
      }
    },
    "invariantPacks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "path"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "domain": { "type": "string" },
          "version": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "title",
          "status",
          "expectation",
          "observed",
          "beforeHash",
          "afterHash",
          "stateDiffs",
          "durationMs"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["fakenet", "poke", "peek", "invariant", "bridge"] },
          "title": { "type": "string" },
          "status": { "enum": ["pass", "warn", "fail"] },
          "actor": { "type": "string" },
          "target": { "type": "string" },
          "expectation": { "type": "string" },
          "observed": { "type": "string" },
          "adapter": {
            "$ref": "#/$defs/adapterObservation"
          },
          "beforeHash": { "type": "string" },
          "afterHash": { "type": "string" },
          "stateDiffs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/stateDiff"
            }
          },
          "durationMs": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "status", "observed", "expected"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "enum": ["critical", "high", "medium", "low"] },
          "status": { "enum": ["pass", "warn", "fail"] },
          "observed": { "type": "string" },
          "expected": { "type": "string" }
        }
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "state", "observed", "condition", "message"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "enum": ["critical", "warning", "info"] },
          "state": { "enum": ["clear", "triggered"] },
          "observed": { "type": "string" },
          "condition": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "adapterObservations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapterObservationSummary"
      }
    },
    "stateDiffs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateDiff"
      }
    },
    "stateSnapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "stateHash", "state"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "stepId": { "type": "string" },
          "stateHash": { "type": "string" },
          "state": {}
        }
      }
    },
    "nextActions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "adapterObservationSummary": {
      "type": "object",
      "required": ["stepId", "kind", "capability", "status", "summary", "checkedAt"],
      "additionalProperties": false,
      "properties": {
        "stepId": { "type": "string" },
        "kind": { "enum": ["local-fakenet"] },
        "capability": { "enum": ["health", "balance", "chain", "poke", "peek"] },
        "status": { "enum": ["pass", "fail"] },
        "target": { "type": "string" },
        "summary": { "type": "string" },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "adapterObservation": {
      "type": "object",
      "required": ["kind", "grpcEndpoint", "reachable", "latencyMs", "checkedAt"],
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["local-fakenet"] },
        "grpcEndpoint": { "type": "string" },
        "reachable": { "type": "boolean" },
        "latencyMs": { "type": "integer", "minimum": 0 },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "balance": {
          "$ref": "#/$defs/balanceObservation"
        },
        "chain": {
          "$ref": "#/$defs/chainObservation"
        },
        "poke": {
          "$ref": "#/$defs/pokeObservation"
        },
        "peek": {
          "$ref": "#/$defs/peekObservation"
        },
        "error": { "type": "string" }
      }
    },
    "balanceObservation": {
      "type": "object",
      "required": ["status", "address", "unit", "raw", "checkedAt"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["pass", "fail"] },
        "address": { "type": "string" },
        "amount": { "type": "number" },
        "unit": { "const": "NOCK" },
        "raw": { "type": "string" },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "error": { "type": "string" }
      }
    },
    "chainObservation": {
      "type": "object",
      "required": ["status", "raw", "checkedAt"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["pass", "fail"] },
        "height": { "type": "integer", "minimum": 0 },
        "peerCount": { "type": "integer", "minimum": 0 },
        "blockId": { "type": "string" },
        "blockCommitment": { "type": "string" },
        "raw": { "type": "string" },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "error": { "type": "string" }
      }
    },
    "peekObservation": {
      "type": "object",
      "required": ["status", "raw", "checkedAt", "expectation"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["pass", "fail"] },
        "raw": { "type": "string" },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "exitCode": {
          "type": "integer",
          "minimum": 0
        },
        "expectation": { "type": "string" },
        "error": { "type": "string" }
      }
    },
    "pokeObservation": {
      "type": "object",
      "required": ["status", "raw", "checkedAt", "expectation"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["pass", "fail"] },
        "raw": { "type": "string" },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "exitCode": {
          "type": "integer",
          "minimum": 0
        },
        "expectation": { "type": "string" },
        "error": { "type": "string" }
      }
    },
    "balanceCheck": {
      "type": "object",
      "required": ["address", "command"],
      "additionalProperties": false,
      "properties": {
        "address": { "type": "string" },
        "command": {
          "$ref": "#/$defs/command"
        }
      }
    },
    "chainCheck": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "$ref": "#/$defs/command"
        }
      }
    },
    "command": {
      "type": "object",
      "required": ["program"],
      "additionalProperties": false,
      "properties": {
        "program": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "stateDiff": {
      "type": "object",
      "required": ["path", "before", "after"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "before": { "type": "string" },
        "after": { "type": "string" }
      }
    }
  }
}
