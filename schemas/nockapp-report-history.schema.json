{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nocksperimental.dev/schemas/nockapp-report-history.schema.json",
  "title": "Nocksperimental Report History",
  "type": "object",
  "required": ["version", "reports"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "reports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "workspaceSlug",
          "workspaceName",
          "appName",
          "fixtureId",
          "reportSlug",
          "status",
          "stage",
          "generatedAt",
          "invariantPacks",
          "snapshotsCaptured",
          "summary"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "workspaceSlug": { "type": "string" },
          "workspaceName": { "type": "string" },
          "appName": { "type": "string" },
          "fixtureId": { "type": "string" },
          "reportSlug": { "type": "string" },
          "status": { "enum": ["pass", "warn", "fail"] },
          "stage": {
            "enum": ["pre-launch", "audit", "upgrade", "integration"]
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "invariantPacks": {
            "type": "array",
            "items": { "type": "string" }
          },
          "snapshotsCaptured": {
            "type": "integer",
            "minimum": 0
          },
          "summary": {
            "type": "string"
          }
        }
      }
    }
  }
}
