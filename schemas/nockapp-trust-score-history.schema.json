{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nocksperimental.dev/schemas/nockapp-trust-score-history.schema.json",
  "title": "Nocksperimental Trust Score History Store",
  "type": "object",
  "required": ["$schema", "version", "storage", "histories"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "storage": {
      "type": "object",
      "required": ["backend", "source", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "backend": {
          "enum": ["static-json"]
        },
        "source": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "histories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scoreHistory"
      }
    }
  },
  "$defs": {
    "scoreHistory": {
      "type": "object",
      "required": [
        "id",
        "signalKind",
        "signalId",
        "label",
        "sampleWindowDays",
        "sourceReports",
        "points"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "signalKind": {
          "enum": ["solver-score", "token-compatibility", "compute-benchmark"]
        },
        "signalId": { "type": "string" },
        "label": { "type": "string" },
        "sampleWindowDays": {
          "type": "integer",
          "minimum": 1
        },
        "sourceReports": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/scoreHistoryPoint"
          }
        }
      }
    },
    "scoreHistoryPoint": {
      "type": "object",
      "required": ["recordedAt", "score", "status", "reportSlug", "fixtureId", "evidenceHash"],
      "additionalProperties": false,
      "properties": {
        "recordedAt": {
          "type": "string",
          "format": "date-time"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "type": "string"
        },
        "reportSlug": { "type": "string" },
        "fixtureId": { "type": "string" },
        "evidenceHash": { "type": "string" }
      }
    }
  }
}
