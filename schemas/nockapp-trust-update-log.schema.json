{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nocksperimental.dev/schemas/nockapp-trust-update-log.schema.json",
  "title": "Nocksperimental Trust Update Log",
  "type": "object",
  "required": ["$schema", "version", "chain", "entries"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "chain": {
      "type": "object",
      "required": ["algorithm", "source", "entryCount", "latestRoot"],
      "additionalProperties": false,
      "properties": {
        "algorithm": { "type": "string" },
        "source": { "type": "string" },
        "entryCount": {
          "type": "integer",
          "minimum": 1
        },
        "latestRoot": { "type": "string" }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/trustUpdateEntry"
      }
    }
  },
  "$defs": {
    "trustUpdateEntry": {
      "type": "object",
      "required": [
        "sequence",
        "id",
        "action",
        "target",
        "targetPath",
        "recordedAt",
        "previousRoot",
        "entryHash",
        "rootHash",
        "summary",
        "signature"
      ],
      "additionalProperties": false,
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "id": { "type": "string" },
        "action": {
          "enum": [
            "registry-snapshot",
            "badge-issuance",
            "badge-revocation",
            "score-history"
          ]
        },
        "target": {
          "enum": ["trust-signals", "badge-issuance", "badge-revocation", "score-history"]
        },
        "targetPath": { "type": "string" },
        "recordedAt": {
          "type": "string",
          "format": "date-time"
        },
        "previousRoot": { "type": "string" },
        "entryHash": { "type": "string" },
        "rootHash": { "type": "string" },
        "summary": { "type": "string" },
        "signature": {
          "type": "object",
          "required": ["issuerKeyId", "algorithm", "signature", "verificationStatus"],
          "additionalProperties": false,
          "properties": {
            "issuerKeyId": { "type": "string" },
            "algorithm": { "type": "string" },
            "signature": { "type": "string" },
            "verificationStatus": {
              "enum": ["valid", "invalid", "unchecked"]
            }
          }
        }
      }
    }
  }
}
