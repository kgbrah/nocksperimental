{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nocksperimental.dev/schemas/nockapp-invariant-pack.schema.json",
  "title": "Nocksperimental Invariant Pack",
  "type": "object",
  "required": ["id", "name", "version", "domain", "description", "invariants"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "domain": {
      "enum": ["payments", "intents", "token-issuance", "bridge-settlement", "pma-safety", "mining-pow"]
    },
    "description": {
      "type": "string"
    },
    "upstreamBasis": {
      "type": "object",
      "required": ["repo", "commit"],
      "additionalProperties": false,
      "properties": {
        "repo": { "type": "string" },
        "commit": { "type": "string" },
        "build": { "type": "string" },
        "protocolTrack": { "type": "string" }
      }
    },
    "sourceAnchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "upstreamFile"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "upstreamRepo": { "type": "string" },
          "upstreamFile": { "type": "string" },
          "upstreamUrl": { "type": "string" },
          "docTier": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/invariant"
      }
    }
  },
  "$defs": {
    "invariant": {
      "type": "object",
      "required": ["id", "title", "severity", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "severity": {
          "enum": ["critical", "high", "medium", "low"]
        },
        "kind": {
          "enum": [
            "numeric-min",
            "state-equals",
            "poke-actors-declared",
            "supply-conservation",
            "timeline-state",
            "authorized-actor",
            "numeric-range",
            "array-length-min",
            "array-length-max",
            "temporal-ordering",
            "custom-function"
          ]
        },
        "path": { "type": "string" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "equals": {},
        "balancesPath": { "type": "string" },
        "supplyPath": { "type": "string" },
        "actors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stepType": {
          "enum": ["fakenet", "poke", "peek", "invariant", "bridge"]
        },
        "field": { "type": "string" },
        "before": {},
        "after": {},
        "fn": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "numeric-min" } } },
          "then": { "required": ["path", "min"] }
        },
        {
          "if": { "properties": { "kind": { "const": "state-equals" } } },
          "then": { "required": ["path", "equals"] }
        },
        {
          "if": { "properties": { "kind": { "const": "timeline-state" } } },
          "then": { "required": ["path", "equals"] }
        },
        {
          "if": { "properties": { "kind": { "const": "supply-conservation" } } },
          "then": { "required": ["balancesPath", "supplyPath"] }
        },
        {
          "if": { "properties": { "kind": { "const": "authorized-actor" } } },
          "then": {
            "required": ["actors", "stepType"],
            "properties": { "actors": { "minItems": 1 } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "numeric-range" } } },
          "then": { "required": ["path", "min", "max"] }
        },
        {
          "if": { "properties": { "kind": { "const": "array-length-min" } } },
          "then": { "required": ["path", "min"] }
        },
        {
          "if": { "properties": { "kind": { "const": "array-length-max" } } },
          "then": { "required": ["path", "max"] }
        },
        {
          "if": { "properties": { "kind": { "const": "temporal-ordering" } } },
          "then": { "required": ["path", "field", "before", "after"] }
        },
        {
          "if": { "properties": { "kind": { "const": "custom-function" } } },
          "then": { "required": ["fn", "path"] }
        }
      ]
    }
  }
}
