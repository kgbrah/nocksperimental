{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nocksperimental.dev/schemas/nockapp-trust-signal.schema.json",
  "title": "Nocksperimental Trust Signal Registry",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "verifiedBadges",
    "badgeIssuanceReceipts",
    "badgeRevocations",
    "solverScorecards",
    "tokenCompatibilityReports",
    "computeBenchmarkProfiles",
    "trustConsumers"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "verifiedBadges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/verifiedBadge"
      }
    },
    "badgeIssuanceReceipts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/badgeIssuanceReceipt"
      }
    },
    "badgeRevocations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/badgeRevocation"
      }
    },
    "solverScorecards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/solverScorecard"
      }
    },
    "tokenCompatibilityReports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tokenCompatibilityReport"
      }
    },
    "computeBenchmarkProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/computeBenchmarkProfile"
      }
    },
    "trustConsumers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/trustConsumer"
      }
    }
  },
  "$defs": {
    "sourceAnchor": {
      "type": "object",
      "required": ["commit", "build"],
      "additionalProperties": false,
      "properties": {
        "commit": { "type": "string" },
        "build": { "type": "string" },
        "workspaceMemberHash": { "type": "string" },
        "sourceRefs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "verifiedBadge": {
      "type": "object",
      "required": [
        "id",
        "label",
        "kind",
        "status",
        "reportSlug",
        "fixtureId",
        "issuedAt",
        "expiresAt",
        "issuer",
        "evidence",
        "sourceAnchor"
      ],
      "additionalProperties": false,
      "properties": {
        "sourceAnchor": { "$ref": "#/$defs/sourceAnchor" },
        "id": { "type": "string" },
        "label": { "type": "string" },
        "kind": {
          "enum": ["app-report", "solver-score", "token-compatibility", "compute-benchmark"]
        },
        "status": {
          "enum": ["verified", "watch", "revoked", "expired"]
        },
        "reportSlug": { "type": "string" },
        "fixtureId": { "type": "string" },
        "issuedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "issuer": { "type": "string" },
        "evidence": {
          "type": "object",
          "required": ["reportHash", "snapshotRoot", "signature", "invariantPacks"],
          "additionalProperties": false,
          "properties": {
            "reportHash": { "type": "string" },
            "snapshotRoot": { "type": "string" },
            "signature": { "type": "string" },
            "invariantPacks": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "badgeIssuanceReceipt": {
      "type": "object",
      "required": [
        "id",
        "badgeId",
        "issuedAt",
        "issuer",
        "issuerKeyId",
        "payloadDigest",
        "signature",
        "signedPayload",
        "verification"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "badgeId": { "type": "string" },
        "issuedAt": {
          "type": "string",
          "format": "date-time"
        },
        "issuer": { "type": "string" },
        "issuerKeyId": { "type": "string" },
        "payloadDigest": { "type": "string" },
        "signature": { "type": "string" },
        "signedPayload": {
          "type": "object",
          "required": [
            "badgeId",
            "status",
            "reportHash",
            "snapshotRoot",
            "issuedAt",
            "expiresAt",
            "sourceAnchor"
          ],
          "additionalProperties": false,
          "properties": {
            "badgeId": { "type": "string" },
            "status": {
              "enum": ["verified", "watch", "revoked", "expired"]
            },
            "reportHash": { "type": "string" },
            "snapshotRoot": { "type": "string" },
            "issuedAt": {
              "type": "string",
              "format": "date-time"
            },
            "expiresAt": {
              "type": "string",
              "format": "date-time"
            },
            "sourceAnchor": { "$ref": "#/$defs/sourceAnchor" }
          }
        },
        "verification": {
          "type": "object",
          "required": ["status", "algorithm", "checkedAt"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "enum": ["valid", "invalid", "unchecked"]
            },
            "algorithm": { "type": "string" },
            "checkedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "badgeRevocation": {
      "type": "object",
      "required": [
        "id",
        "badgeId",
        "statusBeforeRevocation",
        "revokedAt",
        "revokedBy",
        "reason",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "badgeId": { "type": "string" },
        "statusBeforeRevocation": {
          "enum": ["verified", "watch", "expired"]
        },
        "revokedAt": {
          "type": "string",
          "format": "date-time"
        },
        "revokedBy": { "type": "string" },
        "reason": { "type": "string" },
        "replacementBadgeId": { "type": "string" },
        "evidence": {
          "type": "object",
          "required": ["reportHash", "snapshotRoot", "signature"],
          "additionalProperties": false,
          "properties": {
            "reportHash": { "type": "string" },
            "snapshotRoot": { "type": "string" },
            "signature": { "type": "string" }
          }
        }
      }
    },
    "solverScorecard": {
      "type": "object",
      "required": ["id", "solverSlug", "solverName", "status", "score", "grade", "reportSlug", "fixtureId", "metrics", "signals"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "solverSlug": { "type": "string" },
        "solverName": { "type": "string" },
        "status": {
          "enum": ["qualified", "watch", "blocked"]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "grade": {
          "enum": ["A", "B", "C", "D", "F"]
        },
        "reportSlug": { "type": "string" },
        "fixtureId": { "type": "string" },
        "metrics": {
          "type": "object",
          "required": ["fillRate", "failureRate", "medianSettlementMs", "proofLatencyMs", "replayCount"],
          "additionalProperties": false,
          "properties": {
            "fillRate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "failureRate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "medianSettlementMs": {
              "type": "integer",
              "minimum": 0
            },
            "proofLatencyMs": {
              "type": "integer",
              "minimum": 0
            },
            "replayCount": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tokenCompatibilityReport": {
      "type": "object",
      "required": ["id", "tokenSymbol", "issuerWorkspace", "status", "score", "reportSlug", "fixtureId", "badgeId", "wallets", "requirements"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "tokenSymbol": { "type": "string" },
        "issuerWorkspace": { "type": "string" },
        "status": {
          "enum": ["compatible", "partial", "incompatible"]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "reportSlug": { "type": "string" },
        "fixtureId": { "type": "string" },
        "badgeId": { "type": "string" },
        "wallets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "status", "notes"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "status": {
                "enum": ["pass", "warn", "fail"]
              },
              "notes": { "type": "string" }
            }
          }
        },
        "requirements": {
          "type": "object",
          "required": ["supplyConserved", "metadataStable", "authorizedIssuance", "transferCompatible"],
          "additionalProperties": false,
          "properties": {
            "supplyConserved": { "type": "boolean" },
            "metadataStable": { "type": "boolean" },
            "authorizedIssuance": { "type": "boolean" },
            "transferCompatible": { "type": "boolean" }
          }
        }
      }
    },
    "computeBenchmarkProfile": {
      "type": "object",
      "required": ["id", "providerSlug", "providerName", "status", "score", "benchmarkReportSlug", "badgeId", "jobClasses", "sla"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "providerSlug": { "type": "string" },
        "providerName": { "type": "string" },
        "status": {
          "enum": ["qualified", "watch", "blocked"]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "benchmarkReportSlug": { "type": "string" },
        "badgeId": { "type": "string" },
        "jobClasses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "score", "p50Ms", "p95Ms", "reproducibility"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "p50Ms": {
                "type": "integer",
                "minimum": 0
              },
              "p95Ms": {
                "type": "integer",
                "minimum": 0
              },
              "reproducibility": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        },
        "sla": {
          "type": "object",
          "required": ["uptime", "failureRate", "sampleSize"],
          "additionalProperties": false,
          "properties": {
            "uptime": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "failureRate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "sampleSize": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "trustConsumer": {
      "type": "object",
      "required": ["id", "name", "category", "uses"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": {
          "enum": ["app", "wallet", "fund", "provider"]
        },
        "uses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["kind", "purpose"],
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": ["badge", "solver-score", "token-compatibility", "compute-benchmark"]
              },
              "badgeId": { "type": "string" },
              "scorecardId": { "type": "string" },
              "compatibilityReportId": { "type": "string" },
              "benchmarkProfileId": { "type": "string" },
              "reportSlug": { "type": "string" },
              "purpose": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
