{
  "$schema": "../schemas/nockapp-lab-fixture.schema.json",
  "id": "attack-xchain-signature-replay-v0",
  "expectRejected": true,
  "app": {
    "name": "ATTACK: signature-replay",
    "slug": "attack-xchain-signature-replay",
    "version": "0.0.1",
    "kernel": "xchain-attack-model"
  },
  "environment": {
    "mode": "mock-fakenet",
    "grpcEndpoint": "n/a",
    "fakenetCommand": "model",
    "notes": [
      "NEGATIVE CONTROL (expectRejected=true): a multi-EVM cross-chain exploit the invariant MUST catch.",
      "One 3-of-5 attestation signed for Arbitrum (42161) replayed to mint on Optimism (10).",
      "expectRejected inverts a CAUGHT exploit to a green proof-of-prevention."
    ]
  },
  "actors": [
    {
      "name": "attacker",
      "pkh": "attacker"
    }
  ],
  "initialState": {
    "xchain": {
      "crosschain": {
        "messages": [
          {
            "id": "wd-001",
            "targetChainId": 10,
            "attestation": {
              "signedPayloadIncludesChainId": true,
              "signedChainId": 42161,
              "eip155": true
            },
            "attestedBy": [
              "n1",
              "n2",
              "n3"
            ]
          }
        ]
      }
    }
  },
  "steps": [
    {
      "id": "observe",
      "type": "bridge",
      "title": "Observe terminal joint multi-EVM state",
      "operations": [
        {
          "kind": "set",
          "path": "xchain.observed",
          "value": true
        }
      ],
      "expect": {
        "path": "xchain.observed",
        "equals": true
      }
    }
  ],
  "invariants": [
    {
      "id": "chainid-bound",
      "title": "Signed payload must bind the target chain",
      "severity": "critical",
      "kind": "custom-function",
      "fn": "xchain-chainid-bound",
      "path": "xchain.crosschain"
    }
  ]
}
