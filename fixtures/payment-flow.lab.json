{
  "$schema": "../schemas/nockapp-lab-fixture.schema.json",
  "id": "payment-flow-v0",
  "app": {
    "name": "Payment Flow",
    "slug": "payment-flow",
    "version": "0.1.0",
    "kernel": "mock-payment-v0"
  },
  "environment": {
    "mode": "mock-fakenet",
    "grpcEndpoint": "127.0.0.1:5555",
    "fakenetCommand": "nockchain --fakenet --bind-public-grpc-addr 127.0.0.1:5555 --no-default-peers",
    "notes": [
      "Mock payment lifecycle for escrowed settlement runs.",
      "Uses invariant packs to prove payment safety conditions before a real adapter exists."
    ]
  },
  "actors": [
    {
      "name": "customer",
      "pkh": "payment-customer-mock-pkh"
    },
    {
      "name": "merchant",
      "pkh": "payment-merchant-mock-pkh"
    },
    {
      "name": "escrow-agent",
      "pkh": "payment-escrow-agent-mock-pkh"
    }
  ],
  "invariantPacks": ["../packs/payments.invariants.json"],
  "initialState": {
    "ledger": {
      "totalSupply": 10000,
      "balances": {
        "merchant": 7500,
        "customer": 2500,
        "escrow": 0
      }
    },
    "payment": {
      "status": "created",
      "amount": 1200,
      "receiptId": null,
      "events": []
    },
    "alerts": {
      "failed": false
    }
  },
  "steps": [
    {
      "id": "boot-fakenet",
      "type": "fakenet",
      "title": "Boot mock payment fakenet",
      "expectation": "gRPC endpoint configured at 127.0.0.1:5555"
    },
    {
      "id": "lock-customer-funds",
      "type": "poke",
      "title": "Customer locks payment funds",
      "actor": "customer",
      "target": "/payment/lock",
      "operations": [
        {
          "kind": "transfer",
          "fromPath": "ledger.balances.customer",
          "toPath": "ledger.balances.escrow",
          "amount": 1200
        },
        {
          "kind": "set",
          "path": "payment.status",
          "value": "locked"
        },
        {
          "kind": "append-event",
          "path": "payment.events",
          "value": {
            "type": "locked",
            "actor": "customer"
          }
        }
      ],
      "expect": {
        "path": "payment.status",
        "equals": "locked"
      }
    },
    {
      "id": "merchant-accepts-payment",
      "type": "poke",
      "title": "Merchant accepts payment terms",
      "actor": "merchant",
      "target": "/payment/accept",
      "operations": [
        {
          "kind": "set",
          "path": "payment.status",
          "value": "accepted"
        },
        {
          "kind": "set",
          "path": "payment.receiptId",
          "value": "receipt-001"
        },
        {
          "kind": "append-event",
          "path": "payment.events",
          "value": {
            "type": "accepted",
            "actor": "merchant"
          }
        }
      ],
      "expect": {
        "path": "payment.receiptId",
        "equals": "receipt-001"
      }
    },
    {
      "id": "release-to-merchant",
      "type": "poke",
      "title": "Escrow releases settled payment",
      "actor": "escrow-agent",
      "target": "/payment/release",
      "operations": [
        {
          "kind": "transfer",
          "fromPath": "ledger.balances.escrow",
          "toPath": "ledger.balances.merchant",
          "amount": 1200
        },
        {
          "kind": "set",
          "path": "payment.status",
          "value": "settled"
        },
        {
          "kind": "append-event",
          "path": "payment.events",
          "value": {
            "type": "settled",
            "actor": "escrow-agent"
          }
        }
      ],
      "expect": {
        "path": "ledger.balances.merchant",
        "equals": 8700
      }
    },
    {
      "id": "peek-payment-status",
      "type": "peek",
      "title": "Read settled payment status",
      "target": "/payment",
      "expect": {
        "path": "payment.status",
        "equals": "settled"
      }
    }
  ],
  "invariants": [
    {
      "id": "payment-receipt-recorded",
      "title": "Payment settlement records a receipt",
      "severity": "high",
      "kind": "state-equals",
      "path": "payment.receiptId",
      "equals": "receipt-001"
    },
    {
      "id": "payment-no-failure-alert",
      "title": "Payment failure alert remains clear",
      "severity": "critical",
      "kind": "state-equals",
      "path": "alerts.failed",
      "equals": false
    }
  ]
}
