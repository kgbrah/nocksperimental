{
  "$schema": "../schemas/nockapp-lab-fixture.schema.json",
  "id": "bridge-delayed-v0",
  "app": {
    "name": "Bridge Delayed Alert",
    "slug": "bridge-delayed-alert",
    "version": "0.0.1",
    "kernel": "mock-bridge-monitor-v0"
  },
  "environment": {
    "mode": "mock-fakenet",
    "grpcEndpoint": "127.0.0.1:5555",
    "fakenetCommand": "nockchain --fakenet --bind-public-grpc-addr 127.0.0.1:5555 --no-default-peers",
    "notes": [
      "Mock bridge lifecycle for alert-state reports.",
      "This fixture intentionally triggers a warning, not a failing strict exit."
    ]
  },
  "actors": [
    {
      "name": "relayer",
      "pkh": "bridge-relayer-mock-pkh"
    }
  ],
  "initialState": {
    "settlement": {
      "status": "observed",
      "observedOnBase": true,
      "proofSeen": false,
      "finalized": false,
      "amount": 250,
      "ageBlocks": 18
    },
    "alerts": {
      "delayed": false,
      "failed": false
    }
  },
  "steps": [
    {
      "id": "boot-fakenet",
      "type": "fakenet",
      "title": "Boot mock bridge monitor fakenet",
      "expectation": "gRPC endpoint configured at 127.0.0.1:5555"
    },
    {
      "id": "age-settlement",
      "type": "bridge",
      "title": "Age settlement past delay threshold",
      "target": "/settlement",
      "operations": [
        {
          "kind": "increment",
          "path": "settlement.ageBlocks",
          "by": 14
        },
        {
          "kind": "set",
          "path": "settlement.status",
          "value": "delayed"
        },
        {
          "kind": "set",
          "path": "alerts.delayed",
          "value": true
        }
      ],
      "expect": {
        "path": "alerts.delayed",
        "equals": true
      }
    },
    {
      "id": "peek-delay-state",
      "type": "peek",
      "title": "Read delayed alert state",
      "target": "/alerts",
      "expect": {
        "path": "settlement.status",
        "equals": "delayed"
      }
    }
  ],
  "invariants": [
    {
      "id": "bridge-status-delayed",
      "title": "Bridge reaches delayed state",
      "severity": "medium",
      "kind": "timeline-state",
      "path": "settlement.status",
      "equals": "delayed"
    },
    {
      "id": "no-failure-alert",
      "title": "Failure alert remains clear",
      "severity": "high",
      "kind": "state-equals",
      "path": "alerts.failed",
      "equals": false
    }
  ],
  "alertPolicies": [
    {
      "id": "settlement-delayed",
      "title": "Settlement delay",
      "severity": "warning",
      "condition": {
        "path": "alerts.delayed",
        "equals": true
      },
      "message": "Settlement is delayed and needs operator attention.",
      "clearMessage": "Settlement is not delayed."
    },
    {
      "id": "settlement-failed",
      "title": "Settlement failure",
      "severity": "critical",
      "condition": {
        "path": "alerts.failed",
        "equals": true
      },
      "message": "Settlement failed.",
      "clearMessage": "No settlement failure detected."
    }
  ]
}
