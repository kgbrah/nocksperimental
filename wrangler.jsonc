{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "base_dir": ".open-next",
  "find_additional_modules": true,
  "name": "nocksperimental",
  "compatibility_date": "2026-06-04",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "NOCKS_FAKENET_RECEIPTS",
      "id": "cbdaadccc1d54e4e84c197559a592230"
    },
    {
      "binding": "NOCKS_VESL_RECEIPTS",
      "id": "11a8ab977dd84b5fbee0bde2509ecc3c"
    },
    {
      "binding": "NOCKS_NOCKUP_RECEIPTS",
      "id": "b2466d985b9346e4ad569a7b134df7ce"
    },
    {
      // x402 metered-trust receipts (src/lib/x402/kv.ts → X402_KV_BINDING).
      // The namespace is not yet provisioned: before deploying, run
      //   wrangler kv namespace create NOCKS_X402_RECEIPTS
      // and replace the id below. Until then the x402 layer falls back to an
      // in-memory map, so tests and local dev stay green without a binding.
      "binding": "NOCKS_X402_RECEIPTS",
      "id": "REPLACE_WITH_X402_KV_NAMESPACE_ID"
    }
  ],
  "rules": [
    {
      "type": "Data",
      "globs": [
        "server-functions/default/.nocklab/**/*.json"
      ],
      "fallthrough": true
    },
    {
      "type": "Text",
      "globs": [
        "server-functions/default/.nocklab/**/*.md"
      ],
      "fallthrough": true
    }
  ],
  "routes": [
    {
      "pattern": "nocksperimental.com",
      "custom_domain": true
    }
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "nocksperimental"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  }
}
